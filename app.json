{
  "expo": {
    "name": "CardMesh",
    "slug": "cardmesh",
    "scheme": "cardmesh",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#f6efe6"
    },
